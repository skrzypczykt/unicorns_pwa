# Environment variables for E2E tests
# Copy this file to .env.test and fill in the values

# Test user password (same for all test accounts)
# This should match the password set in Supabase Vault (test_user_password)
TEST_USER_PASSWORD=your_password_here

# Base URL for tests (default: https://unicorns-test.netlify.app)
BASE_URL=https://unicorns-test.netlify.app
